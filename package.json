{
  "name": "collaborateam",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "lint-staged": "lint-staged",
    "format": "prettier --write \"**/*.{json,ts,tsx,md,mdx,yaml,yml}\" --cache --cache-location .cache/.prettiercache",
    "check-types": "turbo run check-types",
    "prepare": "husky"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.3.1",
    "@commitlint/config-conventional": "^20.3.1",
    "@workspace/eslint-config": "workspace:*",
    "@workspace/prettier-config": "workspace:*",
    "eslint": "catalog:",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "catalog:",
    "turbo": "^2.9.7"
  },
  "packageManager": "pnpm@10.28.0",
  "engines": {
    "node": ">=24",
    "pnpm": ">=10"
  },
  "lint-staged": {
    "**/*.{js,ts,tsx,json,md,yaml,yml}": [
      "prettier --write",
      "eslint --fix"
    ]
  }
}
